# 景点工具 / Demo
SERPAPI_API_KEY=your_serpapi_key
ATTRACTION_TOOL_DEBUG=false

# 方案 A：Google / Gemini
LLM_PROVIDER=google
GOOGLE_API_KEY=your_google_api_key
GOOGLE_LLM_MODEL=gemini-2.5-flash

# 方案 B：OpenAI 或兼容 OpenAI 的公司网关
COMPANY_API_KEY=your_company_api_key
COMPANY_BASE_URL=https://api.openai.com/v1
COMPANY_LLM_MODEL=gpt-4o-mini
